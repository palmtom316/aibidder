ENV=dev
POSTGRES_DB=aibidder
POSTGRES_USER=aibidder
POSTGRES_PASSWORD=aibidder
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=
AUTO_CREATE_SCHEMA=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=20160
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
STORAGE_ROOT=./storage
STORAGE_BACKEND=local
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=aibidder

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:13000,http://127.0.0.1:13000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
AIBIDDER_WEB_PORT=13000
AIBIDDER_API_PORT=8080
AIBIDDER_POSTGRES_PORT=15432
AIBIDDER_REDIS_PORT=16379
AIBIDDER_MINIO_API_PORT=19000
AIBIDDER_MINIO_CONSOLE_PORT=19001

MODEL_PROVIDER=openai_compatible
DEFAULT_MODEL_NAME=gpt-4.1-mini
MODEL_API_BASE_URL=
MODEL_API_KEY=

RUNTIME_PROVIDER=openai_compatible
RUNTIME_API_BASE_URL=https://api.siliconflow.cn/v1
RUNTIME_API_KEY=
OCR_ROLE_MODEL=deepseek-ai/DeepSeek-OCR
DECOMPOSITION_NAVIGATOR_ROLE_MODEL=deepseek-ai/DeepSeek-V3.2
DECOMPOSITION_EXTRACTOR_ROLE_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
WRITER_ROLE_MODEL=deepseek-ai/DeepSeek-V3
REVIEWER_ROLE_MODEL=deepseek-ai/DeepSeek-R1
ADJUDICATOR_ROLE_MODEL=deepseek-ai/DeepSeek-R1

ASYNC_DOCUMENT_INGESTION=false
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
